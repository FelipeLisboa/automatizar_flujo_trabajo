# =============================================================================
# Copia este archivo a ".env" y ajusta los valores.
# El archivo .env NO se sube a git (secretos / rutas locales).
# =============================================================================

# --- Identidad ---
USUARIO_LOCAL=Felipe
# Nombres sugeridos al escribir (separados por coma). No asignan solos por orden.
PARTICIPANTES_CONOCIDOS=Felipe

# --- Modelos ---
OLLAMA_LLM=ollama/qwen2.5-coder:7b
WHISPER_MODEL=small
WHISPER_INITIAL_PROMPT=Reunión técnica sobre VIGO, DET_MINCO, PCE Web, PCM Api, pipelines, feature, timeout y desarrollo de software.

# --- Captura / UI ---
HOTKEY=ctrl+shift+r
RECORDING_HEARTBEAT_SEC=10

# --- Git en repos de producto ---
AUTO_GIT_COMMIT=true
CONFIRMAR_RESPONSABLES=true

# --- Diarización / voces ---
NOMBRAR_REMOTOS=true
USAR_RECONOCIMIENTO_VOZ=true
VOICE_MATCH_THRESHOLD=0.72
VOICE_AUTO_THRESHOLD=0.78
VOICE_AUTO_APPLY=true
USE_PYANNOTE=true

# Token Hugging Face (pyannote). No lo compartas ni lo subas a git.
HF_TOKEN=

# --- Proyectos (customizables) ---
# Formato: PROYECTO_<clave>=ruta_absoluta_al_repo
# Agrega tantas líneas como quieras. Borra las que no uses.
#
# PROYECTO_vigo_web=C:\Users\TU_USUARIO\Documents\repos\mi_front
# PROYECTO_vigo_api=C:\Users\TU_USUARIO\Documents\repos\mi_api
# PROYECTO_pipelines=C:\Users\TU_USUARIO\Documents\repos\pipelines
# PROYECTO_mi_app=C:\Users\TU_USUARIO\Documents\repos\mi_app

# Sinónimos opcionales (coma): alias=clave_canonica
# ALIAS_PROYECTOS=vigo=vigo_web,front=vigo_web,api=vigo_api
