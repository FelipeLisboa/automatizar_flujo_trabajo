# =============================================================================
# Copia este archivo a ".env" y ajusta los valores a TU máquina / identidad.
# El archivo .env NO se sube a git (secretos / rutas locales).
#
#   copy .env.example .env
#
# =============================================================================

# --- Identidad (obligatorio personalizar) ---
# Nombre con el que te etiquetará el micrófono en la diarización.
USUARIO_LOCAL=TuNombre
# Nombres sugeridos al escribir responsables (separados por coma). No asignan solos.
PARTICIPANTES_CONOCIDOS=TuNombre,Ana,Carlos

# --- Modelos ---
OLLAMA_LLM=ollama/qwen2.5-coder:7b
WHISPER_MODEL=small
# Neutro: no listar nombres de productos (Whisper puede copiarlos a la transcripción)
WHISPER_INITIAL_PROMPT=Reunión de desarrollo de software en español. Tareas, features, dashboard, filtros, paginación, commits y pull requests.

# --- Captura / UI ---
HOTKEY=ctrl+shift+r
RECORDING_HEARTBEAT_SEC=10

# --- Git en repos de producto ---
AUTO_GIT_COMMIT=true
CONFIRMAR_RESPONSABLES=true

# --- Diarización / voces ---
NOMBRAR_REMOTOS=true
USAR_RECONOCIMIENTO_VOZ=true
VOICE_MATCH_THRESHOLD=0.72
VOICE_AUTO_THRESHOLD=0.78
VOICE_AUTO_APPLY=true
# true = pyannote (varios remotos + embeddings). Requiere HF_TOKEN + pip install pyannote.audio omegaconf
USE_PYANNOTE=false

# --- Glosario técnico (aprende vocabulario / correcciones) ---
# Se guarda en .glossary/terms.json (local, no se sube a git)
USAR_GLOSARIO=true
# true = confirmar candidatos en consola tras cada reunión; false = guardar solos
GLOSARIO_CONFIRMAR=true
# Cuántos términos inyectar en el initial_prompt de Whisper
GLOSARIO_MAX_PROMPT_TERMS=40

# Token Hugging Face (pyannote). No lo compartas ni lo subas a git.
HF_TOKEN=

# --- Proyectos (100% customizables) ---
# Formato: PROYECTO_<clave>=ruta_absoluta_al_repo_git
# Agrega tantas líneas como quieras. Borra o comenta las que no uses.
# La <clave> aparece en el menú y en docs/<clave>/.
#
# PROYECTO_mi_front=C:\Users\TU_USUARIO\Documents\repos\mi_front
# PROYECTO_mi_api=C:\Users\TU_USUARIO\Documents\repos\mi_api
# PROYECTO_pipelines=C:\Users\TU_USUARIO\Documents\repos\pipelines
# PROYECTO_novatrack=D:\codigo\NovaTrack

# Sinónimos opcionales (coma): alias=clave_canonica
# ALIAS_PROYECTOS=front=mi_front,api=mi_api,nova=novatrack
